rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helpers ───────────────────────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    // Admin account can read/write any user document
    function isAdmin() {
      return isSignedIn()
        && request.auth.token.email == 'admin@einherjarblitz.com';
    }

    // Rarity & type whitelists for inventory items
    function validRarity(r) {
      return r is string && r in ['mythic', 'legendary', 'epic', 'rare', 'common'];
    }
    function validItemType(t) {
      return t is string && t in ['persona', 'invocacion', 'otros'];
    }

    // ─── User profile ──────────────────────────────────────────────────
    // Owner can read/write own profile.
    // NOTE: economy fields (keys, spheres, nivel, copas, etc.) are writable
    // from the client by design (no Cloud Functions). This is a known trade-off
    // accepted for this phase. Tighten with Cloud Functions later if needed.
    match /users/{userId} {
      allow read, write: if isOwner(userId) || isAdmin();
    }

    // ─── Inventory (gacha rewards) ─────────────────────────────────────
    // Each pull writes one doc. Schema is strictly validated on create.
    // Owner can delete an item when claiming it via PDF (no updates allowed).
    match /users/{userId}/inventory/{itemId} {
      allow read: if isOwner(userId);

      allow create: if isOwner(userId)
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0
        && request.resource.data.name.size() <= 80
        && validItemType(request.resource.data.type)
        && validRarity(request.resource.data.rarity)
        && request.resource.data.obtainedAt is timestamp
        && (request.resource.data.bannerId is string
            || !('bannerId' in request.resource.data));

      allow delete: if isOwner(userId);
      allow update: if false;
    }

    // ─── Store: Products ──────────────────────────────────────────────
    // Products are managed from the dashboard (admin). Clients can only read.
    // Stock updates happen via runTransaction from the client — the transaction
    // reads the doc and writes a decremented stock. This is allowed because the
    // user is signed in and we trust the transaction logic (no price/name changes).
    match /products/{productId} {
      allow read: if isSignedIn();
      // Allow stock decrement via transaction (only the stock field changes)
      allow update: if isSignedIn()
        && request.resource.data.name == resource.data.name
        && request.resource.data.price == resource.data.price
        && request.resource.data.imageUrl == resource.data.imageUrl
        && request.resource.data.stock is int
        && request.resource.data.stock >= 0
        && request.resource.data.stock < resource.data.stock;
      allow create, delete: if false;
    }

    // ─── Store: Purchase history ──────────────────────────────────────
    // Each purchase writes one doc. Owner can read their own history.
    // Owner can delete a purchase when claiming it via PDF (no updates allowed).
    match /users/{userId}/purchases/{purchaseId} {
      allow read: if isOwner(userId);

      allow create: if isOwner(userId)
        && request.resource.data.productId is string
        && request.resource.data.productName is string
        && request.resource.data.productName.size() > 0
        && request.resource.data.productName.size() <= 80
        && request.resource.data.price is int
        && request.resource.data.price >= 0
        && request.resource.data.purchasedAt is timestamp;

      allow delete: if isOwner(userId);
      allow update: if false;
    }

    // ─── Default deny ──────────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
